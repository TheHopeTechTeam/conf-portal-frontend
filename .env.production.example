# Production environment variables for Render
NODE_ENV=production

# API
VITE_API_BASE_URL=https://conf-portal-api.onrender.com
VITE_API_TIMEOUT=90000

# Auth
VITE_SKIP_AUTH=false

# App metadata
VITE_APP_NAME=TheHope Conf Portal
VITE_APP_TITLE=Conference Portal
VITE_APP_VERSION=1.0.0

# Debug
VITE_ENABLE_DEBUG=false
VITE_LOG_LEVEL=info
